'use client'

interface ContactButtonProps {
  listingId: string
  listingName: string
}

export default function ContactButton({ listingId, listingName }: ContactButtonProps) {
  const openModal = () => {
    const modal = document.getElementById(`contact-modal-${listingId}`)
    if (modal) modal.style.display = 'flex'
  }

  return (
    <button
      onClick={openModal}
      className="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700 transition"
    >
      Contact {listingName}
    </button>
  )
}
